# ============================================================
# NEXTJS SAAS STARTER KIT — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# Database (PostgreSQL — use Supabase, Neon, PlanetScale, or Railway)
DATABASE_URL="postgresql://username:password@localhost:5432/saas_starter"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-generate-with-openssl-rand-base64-32"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# OpenAI
OPENAI_API_KEY="sk-..."

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@yourdomain.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="YourSaaS"
